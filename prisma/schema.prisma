generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(VIEWER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum UserRole {
  ADMIN
  VIEWER
}

model Website {
  id                   String        @id @default(cuid())
  name                 String
  url                  String
  type                 WebsiteType   @default(HTTP)
  isActive             Boolean       @default(true)
  checkIntervalSeconds Int           @default(60)
  timeoutSeconds       Int           @default(10)
  expectedStatusCode   Int           @default(200)
  expectedKeyword      String?
  degradedThresholdMs  Int           @default(5000)
  currentStatus        WebsiteStatus @default(UNKNOWN)
  lastCheckedAt        DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  checks    Check[]
  incidents Incident[]
}

enum WebsiteType {
  HTTP
  HTTPS
}

enum WebsiteStatus {
  UP
  DOWN
  DEGRADED
  PAUSED
  UNKNOWN
}

model Check {
  id             String        @id @default(cuid())
  websiteId      String
  status         WebsiteStatus
  statusCode     Int?
  responseTimeMs Int?
  errorMessage   String?
  checkedAt      DateTime      @default(now())

  website Website @relation(fields: [websiteId], references: [id], onDelete: Cascade)

  @@index([websiteId, checkedAt])
}

model Incident {
  id              String         @id @default(cuid())
  websiteId       String
  status          IncidentStatus @default(ACTIVE)
  startedAt       DateTime       @default(now())
  resolvedAt      DateTime?
  durationSeconds Int?
  reason          String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  website          Website           @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  notificationLogs NotificationLog[]

  @@index([websiteId, status])
}

enum IncidentStatus {
  ACTIVE
  RESOLVED
}

model NotificationChannel {
  id         String   @id @default(cuid())
  name       String
  type       String
  configJson Json
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model NotificationLog {
  id           String   @id @default(cuid())
  incidentId   String?
  channelId    String?
  status       String
  sentAt       DateTime @default(now())
  errorMessage String?

  incident Incident? @relation(fields: [incidentId], references: [id], onDelete: SetNull)

  @@index([incidentId])
  @@index([sentAt])
}

model RealtimeEvent {
  id        String   @id @default(cuid())
  type      String
  payload   Json
  createdAt DateTime @default(now())

  @@index([createdAt])
}
